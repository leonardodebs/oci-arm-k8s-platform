{
  "images": {
    "nginx-demo": "iad.ocir.io/$OCI_NAMESPACE/nginx-demo"
  },
  "cluster": {
    "name": "oci-arm-k8s-dev",
    "region": "sa-saopaulo-1",
    "version": "1.30"
  },
  "nodePool": {
    "name": "oke-nodepool",
    "shape": "VM.Standard.A1.Flex",
    "ocpus": 2,
    "memory": 12,
    "count": 2
  },
  "namespace": "production",
  "ingress": {
    "class": "nginx",
    "annotations": {
      "cert-manager.io/cluster-issuer": "letsencrypt-prod"
    }
  },
  "autoscaling": {
    "minReplicas": 1,
    "maxReplicas": 3,
    "targetCPUUtilization": 70
  },
  "resources": {
    "requests": {
      "cpu": "100m",
      "memory": "128Mi"
    },
    "limits": {
      "cpu": "500m",
      "memory": "512Mi"
    }
  }
}